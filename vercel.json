{
  "version": 2,
  "rewrites": [
    { "source": "/((?!api/.*).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" },
        { "key": "X-F5-Demo-App", "value": "biva-bank-real-api-waap-lab" }
      ]
    }
  ]
}
